# ===========================================
# Uplup Wheel Discord Bot Configuration
# ===========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# -------------------------------------------
# DISCORD CONFIGURATION (Required)
# -------------------------------------------
# Get these from https://discord.com/developers/applications

# Your bot token (from Bot > Token)
DISCORD_TOKEN=MTUxMzI0MzU4Mzc3ODM5NDE3Mw.G5-_xt.7Rft1Pwe046Om-lnP39q9nGkv_vniCSZaIdhvk

# Your application ID (from General Information)
DISCORD_CLIENT_ID=1513243583778394173

# -------------------------------------------
# UPLUP API CONFIGURATION (Recommended)
# -------------------------------------------
# Get your API key from https://uplup.com/brand/api-integrations#api-keys
# API access is FREE - create an account at uplup.com
#
# Without API key: /spin commands work, /wheel commands disabled
# With API key: All commands work + saved wheels + usage tracking
#
# Authentication uses Bearer tokens. Your API key IS the token.
# Keys look like: uplup_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your API key (starts with uplup_live_ or uplup_test_)
UPLUP_API_KEY=uplup_live_bfd0c29fd93a824bfe1493f6216de27e

# API base URL (don't change unless using a custom endpoint)
UPLUP_API_BASE_URL=https://api.uplup.com/api/v1
